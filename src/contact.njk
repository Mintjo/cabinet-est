---
layout: base.njk
title: Contact
description: "Contactez le Cabinet EST à Cotonou, Bénin. Formulaire de contact, coordonnées et plan d'accès à Vêdoko."
---

<!-- Bannière de page -->
<section class="page-banner contact-banner">
  <div class="container">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <ol class="breadcrumb-list">
        <li class="breadcrumb-item"><a href="/">Accueil</a></li>
        <li class="breadcrumb-separator">/</li>
        <li class="breadcrumb-item active" aria-current="page">Contact</li>
      </ol>
    </nav>
    <h1 class="page-banner-title">Contactez-nous</h1>
    <p class="page-banner-subtitle">Une question, un devis, une demande d'information ? Notre équipe vous répond rapidement.</p>
  </div>
</section>

<!-- Section principale (Coordonnées + Formulaire) -->
<section class="section animate">
  <div class="container contact-grid">
    <!-- Colonne gauche : Coordonnées -->
    <div>
      <div class="section-title-wrapper left-align" style="margin-bottom: 30px;">
        <span class="eyebrow">Nos coordonnées</span>
        <h2 class="section-title">Nous trouver</h2>
      </div>

      <ul class="footer-contact-list" style="color: var(--color-text); font-size: 1rem; gap: 25px;">
        <!-- Adresse -->
        <li class="footer-contact-item" style="align-items: flex-start;">
          <div class="card-icon secondary" style="margin: 0; width: 44px; height: 44px; background-color: rgba(7, 110, 181, 0.1); flex-shrink: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div>
            <span style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.5px; margin-bottom: 2px;">Adresse</span>
            <span style="font-weight: 600; color: var(--color-primary);">10e Arrondissement, Vêdoko, Cotonou, Bénin</span>
          </div>
        </li>

        <!-- Téléphone / WhatsApp -->
        <li class="footer-contact-item" style="align-items: flex-start;">
          <div class="card-icon secondary" style="margin: 0; width: 44px; height: 44px; background-color: rgba(7, 110, 181, 0.1); flex-shrink: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div>
            <span style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.5px; margin-bottom: 2px;">Téléphone & WhatsApp</span>
            <a href="tel:+2290169700303" style="font-weight: 600; color: var(--color-primary); font-size: 1.1rem; display: block;">+229 01 69 70 03 03</a>
          </div>
        </li>

        <!-- Email -->
        <li class="footer-contact-item" style="align-items: flex-start;">
          <div class="card-icon secondary" style="margin: 0; width: 44px; height: 44px; background-color: rgba(7, 110, 181, 0.1); flex-shrink: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div>
            <span style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.5px; margin-bottom: 2px;">Email</span>
            <a href="mailto:Contact@espacesantetravailleurs.com" style="font-weight: 600; color: var(--color-primary);">Contact@espacesantetravailleurs.com</a>
          </div>
        </li>

        <!-- Site Web -->
        <li class="footer-contact-item" style="align-items: flex-start;">
          <div class="card-icon secondary" style="margin: 0; width: 44px; height: 44px; background-color: rgba(7, 110, 181, 0.1); flex-shrink: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <div>
            <span style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted); letter-spacing: 0.5px; margin-bottom: 2px;">Site Web</span>
            <a href="https://www.espacesantetravailleurs.com" target="_blank" rel="noopener noreferrer" style="font-weight: 600; color: var(--color-primary);">www.espacesantetravailleurs.com</a>
          </div>
        </li>
      </ul>
    </div>

    <!-- Colonne droite : Formulaire -->
    <div>
      <div class="section-title-wrapper left-align" style="margin-bottom: 30px;">
        <h2 class="section-title">Formulaire de contact</h2>
      </div>

      <form name="contact-est" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
        <!-- Champ caché honeypot pour le spam -->
        <p style="display: none;">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          <input type="hidden" name="form-name" value="contact-est" />
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="contact-name" class="form-label">Nom et prénom *</label>
            <input type="text" id="contact-name" name="name" class="form-control" placeholder="Votre nom complet" required>
          </div>
          <div class="form-group">
            <label for="contact-company" class="form-label">Entreprise / Organisation</label>
            <input type="text" id="contact-company" name="company" class="form-control" placeholder="Nom de l'entreprise">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="contact-phone" class="form-label">Téléphone *</label>
            <input type="tel" id="contact-phone" name="phone" class="form-control" placeholder="+229 01 00 00 00" required>
          </div>
          <div class="form-group">
            <label for="contact-email" class="form-label">Email</label>
            <input type="email" id="contact-email" name="email" class="form-control" placeholder="exemple@domain.com">
          </div>
        </div>

        <div class="form-group">
          <label for="contact-service" class="form-label">Type de prestation souhaité</label>
          <select id="contact-service" name="service" class="form-control">
            <option value="">Choisir une prestation</option>
            <option value="embauche">Visite médicale d'embauche</option>
            <option value="periodique">Visite médicale périodique</option>
            <option value="reprise">Visite de reprise</option>
            <option value="vaccination">Vaccination en entreprise</option>
            <option value="formation">Formation SST</option>
            <option value="conseil">Conseil en prévention</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div class="form-group">
          <label for="contact-message" class="form-label">Message *</label>
          <textarea id="contact-message" name="message" class="form-control" rows="5" placeholder="Comment pouvons-nous vous aider ?" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-submit" style="width: 100%; border: none;">Envoyer le message</button>
      </form>
    </div>
  </div>
</section>

<!-- Section Plan d'accès -->
<section class="section section-alternate animate">
  <div class="container">
    <div class="section-title-wrapper">
      <span class="eyebrow">Plan d'accès</span>
      <h2 class="section-title">Nous trouver à Vêdoko</h2>
    </div>
    
    <div style="max-width: 900px; margin: 0 auto; border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-md); border: 1px solid var(--color-border);">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.1741544323224!2d2.3934333999999996!3d6.3715124000000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x10235588383f9821%3A0xe54d4f828a2a7a4f!2sV%C3%AAdoko%2C%20Cotonou!5e0!3m2!1sfr!2sbj!4v1700000000000!5m2!1sfr!2sbj"
        width="100%"
        height="360"
        class="iframe-map"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Localisation Cabinet EST — Vêdoko, Cotonou, Bénin">
      </iframe>
    </div>
  </div>
</section>
