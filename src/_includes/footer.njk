{% from "macros/icon.njk" import icon %}
<footer class="site-footer">
  <div class="container footer-grid footer-3-cols">
    <!-- Colonne 1 : Brand & Info -->
    <div class="footer-brand">
      <img src="/images/logo-est-complet.jpeg" alt="Cabinet EST Logo" class="footer-logo" loading="lazy">
      <p class="footer-slogan">« La santé au travail, c'est notre domaine de compétence ! »</p>
      <div class="footer-info">
        <p>Cabinet Espace Santé des Travailleurs (EST) SARL</p>
        <p style="margin-top: 8px;">RCCM : RB/PKO/25 B 1369</p>
        <p>N° ONMB : 4276/ONMB/ATL/2024</p>
      </div>
    </div>

    <!-- Colonne 2 : Liens rapides -->
    <div class="footer-links">
      <h3 class="footer-col-title">Liens rapides</h3>
      <ul class="footer-links-list">
        <li><a href="/" class="footer-link">Accueil</a></li>
        <li><a href="/apropos/" class="footer-link">À propos</a></li>
        <li><a href="/services/" class="footer-link">Services</a></li>
        <li><a href="/contact/" class="footer-link">Contact</a></li>
        <li><a href="/rendez-vous/" class="footer-link">Prendre RDV</a></li>
      </ul>
    </div>

    <!-- Colonne 3 : Nous trouver -->
    <div class="footer-contact">
      <h3 class="footer-col-title">Nous trouver</h3>
      <ul class="footer-contact-list">
        <li class="footer-contact-item">
          {{ icon("map-pin", 20, "currentColor") }}
          <span>10e Arrondissement Vêdoko Cotonou, Bénin</span>
        </li>
        <li class="footer-contact-item">
          {{ icon("phone", 20, "currentColor") }}
          <a href="tel:+2290169700303">+229 01 69 70 03 03</a>
        </li>
        <li class="footer-contact-item">
          {{ icon("mail", 20, "currentColor") }}
          <a href="mailto:Contact@espacesantetravailleurs.com">Contact@espacesantetravailleurs.com</a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Barre Slogan -->
  <div class="footer-slogan-bar">
    <div class="container">
      <span class="footer-slogan-text">La santé au travail, c'est notre domaine de compétence !</span>
    </div>
  </div>

  <!-- Copyright -->
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {{ site.year }} Cabinet Espace Santé des Travailleurs SARL. Tous droits réservés.</p>
    </div>
  </div>
</footer>
