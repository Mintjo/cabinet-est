{#
  Macro d'icônes SVG "sobre clinique" — Cabinet EST
  Icônes décoratives (aria-hidden), le texte adjacent porte le sens.
  Usage : {% from "macros/icon.njk" import icon %}
          {{ icon("shield-check") }}          → 20px, trait #2b3a67 (tokens)
          {{ icon("calendar-check", 42) }}    → 42px pour les badges .icon-wrap
          {{ icon("phone", 20, "currentColor") }} → override couleur (fonds sombres/colorés)
  Le paramètre `color` est optionnel : par défaut #2b3a67 (ou #25D366 pour whatsapp).
#}
{% macro icon(name, size=20, color="") %}
{%- set stroke = color if color else ("#25D366" if name == "whatsapp" else "#2b3a67") -%}
<svg class="ic" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="{{ stroke }}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
{%- if name == "calendar-check" -%}
<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/>
{%- elif name == "shield-check" -%}
<path d="M12 2 4 5v6c0 5.5 3.8 9.7 8 11 4.2-1.3 8-5.5 8-11V5l-8-3Z"/><path d="m9 12 2 2 4-4"/>
{%- elif name == "scale" -%}
<line x1="12" y1="3" x2="12" y2="21"/><path d="M5 7h14"/><path d="m5 7-3 7a4 4 0 0 0 8 0Z"/><path d="m19 7 3 7a4 4 0 0 1-8 0Z"/>
{%- elif name == "trending-up" -%}
<polyline points="3 17 9 11 13 15 21 6"/><polyline points="14 6 21 6 21 13"/>
{%- elif name == "map-pin" -%}
<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
{%- elif name == "phone" -%}
<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .6 3a2 2 0 0 1-.5 2L8 10a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2-.5c1 .3 2 .5 3 .6a2 2 0 0 1 1.7 2Z"/>
{%- elif name == "mail" -%}
<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/>
{%- elif name == "clock" -%}
<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 15"/>
{%- elif name == "whatsapp" -%}
<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
{%- elif name == "stethoscope" -%}
<path d="M4.5 3H3v5a5 5 0 0 0 10 0V3h-1.5"/><path d="M8 13v3a5 5 0 0 0 10 0v-2"/><circle cx="18" cy="12" r="2.5"/>
{%- elif name == "users" -%}
<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
{%- elif name == "check" -%}
<polyline points="20 6 9 17 4 12"/>
{%- elif name == "chevron-down" -%}
<polyline points="6 9 12 15 18 9"/>
{%- elif name == "globe" -%}
<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
{%- elif name == "award" -%}
<circle cx="12" cy="8" r="6"/><path d="M8.2 13.5 6 22l6-3 6 3-2.2-8.5"/>
{%- elif name == "layers" -%}
<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
{%- elif name == "trending-down" -%}
<polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/>
{%- elif name == "syringe" -%}
<path d="m18 2 4 4"/><path d="m17 7 3-3"/><path d="M19 9 8.7 19.3c-.4.4-.9.6-1.4.6l-2.3.1a1 1 0 0 1-1-1l.1-2.3c0-.5.2-1 .6-1.4L15 5"/><path d="m9 11 3 3"/><path d="m14 6 3 3"/>
{%- elif name == "book" -%}
<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/>
{%- endif -%}
</svg>
{%- endmacro %}
